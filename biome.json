{
  "$schema": "https://biomejs.dev/schemas/latest/schema.json",
  "files": {
    "includes": [
      "**",
      "!!static/img",
      "!!static/fonts",
      "!!static/mindmap.html",
      "!!**/node_modules",
      "!!**/build",
      "!!**/.docusaurus",
      "!!**/.rumdl_cache",
      "!!bun.lock"
    ]
  },
  "formatter": { "enabled": true, "indentStyle": "space" },
  "linter": { "enabled": true, "rules": { "preset": "recommended" } },
  "javascript": { "formatter": { "quoteStyle": "single" } }
}
